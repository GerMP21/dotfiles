* {
    text-color:  #C5C8C6;
    background-color: rgba(0,0,0,0);

	background: #282A2E;
	background-alt: #373B41;
	primary: #e0af68;
}
window {
    height:   80%;
    width: 20em;
    location: west;
    anchor:   west;
}
inputbar {
    background-color: @background-alt;
    padding: 4px;
}
mainbox {
    background-color: @background;
    spacing: 1em;
}
listview {
    padding: 0em 0.4em 0em 1em;
    dynamic: false;
    lines: 0;
}
element-text selected  normal {
	text-color: @primary;
}
